rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /members/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId
        && (!('role' in request.resource.data) || request.resource.data.role == "MEMBER")
        && (!('isAdmin' in request.resource.data) || request.resource.data.isAdmin == false)
        && (!('gemachAdminIds' in request.resource.data))
        && (!('creditBalance' in request.resource.data) || request.resource.data.creditBalance == 0);
      allow update: if request.auth != null && request.auth.uid == userId
        && (!('role' in request.resource.data)
            || request.resource.data.role == resource.data.get('role', "MEMBER"))
        && (!('isAdmin' in request.resource.data)
            || request.resource.data.isAdmin == resource.data.get('isAdmin', false))
        && (!('gemachAdminIds' in request.resource.data)
            || request.resource.data.gemachAdminIds == resource.data.get('gemachAdminIds', []))
        && (!('creditBalance' in request.resource.data)
            || request.resource.data.creditBalance == resource.data.get('creditBalance', 0));
    }

    match /credit_ledger/{entryId} {
      allow read: if request.auth != null
        && resource.data.memberId == request.auth.uid;
      allow write: if false;
    }

    match /credit_loans/{loanId} {
      allow read: if request.auth != null
        && (resource.data.borrowerId == request.auth.uid
            || resource.data.lenderId == request.auth.uid);
      allow write: if false;
    }

    match /gemachim/{gemachId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /tools/{toolId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /reservations/{reservationId} {
      allow read: if request.auth != null
        && resource.data.memberId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.memberId == request.auth.uid;
      allow update, delete: if false;
    }

    match /loans/{loanId} {
      allow read: if request.auth != null
        && resource.data.memberId == request.auth.uid;
      allow write: if false;
    }

    match /transactions/{txnId} {
      allow read: if false;
      allow write: if false;
    }

    match /device_pots/{potId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /operations_pot/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /maintenance_tickets/{ticketId} {
      allow read: if request.auth != null
        && resource.data.memberId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.memberId == request.auth.uid;
      allow update, delete: if false;
    }

    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /payments/{paymentId} {
      allow read: if request.auth != null
        && resource.data.memberId == request.auth.uid;
      allow write: if false;
    }

    match /paybox_payouts/{payoutId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
